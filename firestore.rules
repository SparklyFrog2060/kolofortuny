rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Uproszczone reguły: każdy może czytać i pisać w kołach i wyzwaniach.
    // To pozwala na wspólne korzystanie z aplikacji bez barier prywatności.
    match /wheels/{wheelId} {
      allow read, write: if true;
      
      match /challenges/{challengeId} {
        allow read, write: if true;
      }
    }

    // Nowa kolekcja graczy: niezbędna do działania systemu geofencingu i mapy w czasie rzeczywistym.
    match /players/{playerId} {
      allow read, write: if true;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}